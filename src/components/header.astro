---
import Link from '@/components/link.astro'
import ThemeToggle from '@/components/theme-toggle.astro'
import { NAV_LINKS, SITE } from '@/consts'
import { Icon } from 'astro-icon/components'
---

<div>
  <div
    class="mx-auto flex max-w-3xl items-center justify-between gap-4 px-4 py-3"
  >
    <Link href="/" class="flex shrink-0 items-center justify-center gap-2 text-lg font-medium">
      <img src="/rose-emoji.png" alt="" class="size-6" aria-hidden="true" />
      <span>{SITE.title}</span>
    </Link>

    <div class="flex items-center gap-4">
      <nav class="hidden items-center gap-4 text-sm md:flex md:gap-6">
        {
          NAV_LINKS.map((item) => (
            <Link
              href={item.href}
              class="text-foreground/60 hover:text-foreground capitalize transition-colors"
            >
              {item.label}
            </Link>
          ))
        }
      </nav>

      <details class="relative md:hidden">
        <summary class="inline-flex items-center gap-2 rounded-md border border-border bg-background px-3 py-2 text-sm font-medium text-foreground transition hover:bg-muted focus:outline-none focus:ring-2 focus:ring-ring/50">
          <Icon name="lucide:menu" class="size-4" />
          Menu
        </summary>
        <div class="absolute right-0 top-full z-20 mt-2 min-w-[180px] overflow-hidden rounded-md border border-border bg-background shadow-lg">
          <nav class="flex flex-col p-2">
            {
              NAV_LINKS.map((item) => (
                <Link
                  href={item.href}
                  class="block w-full rounded-md px-3 py-2 text-left text-sm text-foreground/80 transition hover:bg-muted hover:text-foreground capitalize"
                >
                  {item.label}
                </Link>
              ))
            }
          </nav>
        </div>
      </details>

      <ThemeToggle transition:persist />

    </div>
  </div>
</div>
